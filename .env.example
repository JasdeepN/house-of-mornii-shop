# Shopify Storefront API
# Copy this file to .env.local and replace with your actual credentials.
# The app runs in demo mode (placeholder products) until these are set.

VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-public-access-token
VITE_SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-api-access-token

# Note: VITE_SHOPIFY_ADMIN_ACCESS_TOKEN is used for products/collections queries.
# VITE_SHOPIFY_STOREFRONT_TOKEN is still required for cart operations (not available in Admin API).

# Public site configuration
# Dev/prototype builds can keep placeholder values here. Production should use
# GitHub Actions variables or Cloudflare Pages environment variables for final copy.
VITE_SITE_NAME=House of Mornii
VITE_SITE_TITLE=House of Mornii Preview
VITE_SITE_DESCRIPTION=Regal costume jewellery showcase in development. Final product, policy, contact, and marketing integrations are configured by environment.
VITE_SITE_URL=http://localhost:5173
VITE_SITE_OG_IMAGE_PATH=/og-image.png
VITE_SITE_OG_IMAGE_ALT=House of Mornii preview image
VITE_THEME_COLOR=oklch(0.15 0.02 210)

# Public contact placeholders
# Leave blank until business-owned contact details are ready.
VITE_CONTACT_EMAIL=
VITE_INSTAGRAM_HANDLE=@houseofmornii
VITE_INSTAGRAM_URL=https://instagram.com/houseofmornii
VITE_CONTACT_LOCATION_LABEL=Appointment details coming soon

# Provider-neutral newsletter hook
# Leave blank for prototype/demo mode. Set to a relative or absolute endpoint
# when the final email platform/API is ready.
VITE_NEWSLETTER_ENDPOINT=
VITE_NEWSLETTER_EYEBROW=Join the House of Mornii list
VITE_NEWSLETTER_PLACEHOLDER=your@email.com
VITE_NEWSLETTER_CTA=Join
VITE_NEWSLETTER_LOADING_LABEL=Joining...
VITE_NEWSLETTER_SUCCESS_MESSAGE=Thank you. We will share updates as the collection opens.
VITE_NEWSLETTER_ERROR_MESSAGE=We could not save your email yet. Please try again.
VITE_WELCOME_POPUP_EYEBROW=Welcome
VITE_WELCOME_POPUP_TITLE=House of Mornii Preview
VITE_WELCOME_POPUP_DESCRIPTION=Join the list for collection previews and launch updates.

# Analytics (optional — omit to disable tracking)
# GA4 measurement ID from Google Analytics 4 (Settings → Data Streams → Measurement ID)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID from Events Manager → Data Sources (numeric, e.g. 1234567890)
VITE_META_PIXEL_ID=
